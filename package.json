{
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@node-rs/bcrypt": "^1.10.7",
    "@node-rs/crc32": "^1.10.6",
    "sqlite-napi": "1.2.0"
  },
  "devDependencies": {
    "jscpd": "4.0.9",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1"
  },
  "private": true,
  "scripts": {
    "postinstall": "chmod +x node_modules/@oxlint-tsgolint/*/tsgolint 2>/dev/null || true",
